# ============================================================
# Variables de entorno - Tarea 3 (PostgreSQL Wire Protocol)
# Copiar a .env y ajustar si es necesario:  cp .env.example .env
# ============================================================

# --- Credenciales PostgreSQL (idénticas a la Tarea 2) ---
POSTGRES_USER=taller
POSTGRES_PASSWORD=tallerpass
POSTGRES_DB=tallerdb

# --- Topología de red (red bridge dedicada redpsql) ---
PG_SUBNET=172.18.0.0/16
SERVER_IP=172.18.0.2
CLIENT_IP=172.18.0.3
SCAPY_IP=172.18.0.4

# --- Hostnames / contenedores ---
SERVER_HOST=servidor          # hostname del contenedor servidor en redpsql
SERVER_CONTAINER=psql-servidor
CLIENT_CONTAINER=psql-cliente
SCAPY_CONTAINER=scapy_mitm

# --- Puertos ---
PG_PORT=5432                  # puerto real del servidor PostgreSQL
PROXY_PORT=5433               # puerto en el que escucha el proxy MITM (scapy)

# NOTA: La contraseña NO aparece en el informe de la Tarea 2 porque el
# protocolo SCRAM-SHA-256 nunca la transmite por la red. Aquí se fija un
# valor (tallerpass) para poder reproducir el entorno; cámbielo si dispone
# de la contraseña original usada por el grupo.
